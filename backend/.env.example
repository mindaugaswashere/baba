# Copy to .env (or just run `./scripts/db.sh init`, which generates a real one).
# Never commit the real .env.

# --- Database ---
# Points at the project-local cluster created by scripts/db.sh (port 5433).
DATABASE_URL=postgres://authapp:CHANGE_ME@127.0.0.1:5433/auth_demo

# --- Auth ---
# Use a long random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
# Session lifetime in seconds (default 7 days).
JWT_TTL_SECONDS=604800

# --- HTTP server ---
BIND_ADDR=127.0.0.1:8080
COOKIE_NAME=auth_token
# Set to true only when serving over HTTPS.
COOKIE_SECURE=false
# Origin allowed to make credentialed cross-origin API calls (the Vite dev server).
# IMPORTANT: with credentials enabled this MUST be an exact, trusted origin —
# never a wildcard. In production set it to your real frontend domain.
CORS_ORIGIN=http://127.0.0.1:5174

RUST_LOG=info,tower_http=info,auth_backend=debug
